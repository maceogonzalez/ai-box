# AI Providers
OPENAI_API_KEY=sk-your-openai-api-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
AZURE_OPENAI_API_KEY=your-azure-openai-key-here
MISTRAL_API_KEY=your-mistral-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here

# LiteLLM
# Generate with: openssl rand -base64 32
LITELLM_MASTER_KEY=sk-your-generated-master-key-here
LITELLM_SALT_KEY=your-generated-salt-key-here
LITELLM_UI_USERNAME=admin
LITELLM_UI_PASSWORD=your-secure-admin-password-here
LITELLM_DB_PASSWORD=your-secure-litellm-db-password-here

# PostgreSQL
POSTGRES_PASSWORD=your-secure-postgres-password-here

# OpenWebUI
WEBUI_URL=http://localhost:3001
WEBUI_SECRET_KEY=your-secret-key-here

# Microsoft SSO (Azure AD)
MICROSOFT_CLIENT_ID=your-client-id-here
MICROSOFT_CLIENT_SECRET=your-client-secret-here
MICROSOFT_CLIENT_TENANT_ID=your-tenant-id-here
MICROSOFT_REDIRECT_URI=http://localhost:3001/oauth/microsoft/callback
OPENID_PROVIDER_URL=https://login.microsoftonline.com/your-tenant-id/v2.0/.well-known/openid-configuration

# Langfuse (set after first launch — see README Langfuse Setup section)
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key-here
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key-here

# user-sync
OPENWEBUI_API_KEY=your-openwebui-api-key-here
DEFAULT_USER_BUDGET=100
DEFAULT_USER_ROLE=internal_user
USER_SYNC_INTERVAL=60
