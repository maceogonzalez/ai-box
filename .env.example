# OpenAI API Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic API Configuration
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Google Gemini API Configuration (Optional)
GEMINI_API_KEY=your-gemini-api-key-here

# Mistral API Configuration (Optional)
MISTRAL_API_KEY=your-mistral-api-key-here

# Azure OpenAI Configuration (Optional)
AZURE_OPENAI_API_KEY=your-azure-openai-key-here

# LiteLLM Configuration
# Generate a secure random key for master key (e.g., using: openssl rand -base64 32)
LITELLM_MASTER_KEY=sk-your-generated-master-key-here

# Generate a secure random salt key (e.g., using: openssl rand -base64 32)
LITELLM_SALT_KEY=your-generated-salt-key-here

# LiteLLM UI Credentials
LITELLM_UI_USERNAME=admin
LITELLM_UI_PASSWORD=your-secure-admin-password-here

# PostgreSQL Configuration
POSTGRES_PASSWORD=your-secure-postgres-password-here
LITELLM_DB_PASSWORD=your-secure-litellm-db-password-here

# Optional: LiteLLM Base URL (default: http://localhost:4000)
# LITELLM_BASE_URL=http://localhost:4000
